{
  "extends": ["@tsconfig/recommended/tsconfig.json", "@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "customConditions": ["workerd", "worker"],
    "lib": ["ES2024", "WebWorker"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "rootDir": ".",
    "target": "ES2024",
    "types": ["@cloudflare/vitest-pool-workers/types", "@cloudflare/workers-types", "node"]
  },
  "include": [
    "packages/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts",
    "workers/**/*.ts"
  ]
}
