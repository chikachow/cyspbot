{
  "name": "@cyspbot/token-exchange",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./authentication": "./src/authentication.ts",
    "./dependencies": "./src/dependencies.ts",
    "./oidc-issuers": "./src/oidc-issuers.ts",
    "./policy/fly-machine-token-policy-rule": "./src/policy/fly-machine-token-policy-rule.ts",
    "./policy/token-policy": "./src/policy/token-policy.ts",
    "./policy/token-policy-rules": "./src/policy/token-policy-rules.ts",
    "./token-exchange": "./src/token-exchange.ts",
    "./worker": "./src/worker.ts"
  },
  "scripts": {
    "check": "node --run wrangler:check",
    "dev": "WRANGLER_LOG=none WRANGLER_LOG_PATH=../../.wrangler/logs WRANGLER_REGISTRY_PATH=../../.wrangler/registry wrangler dev --config wrangler.jsonc --env-file ../../.dev.vars",
    "wrangler:check": "WRANGLER_LOG=none WRANGLER_LOG_PATH=../../.wrangler/logs WRANGLER_REGISTRY_PATH=../../.wrangler/registry wrangler deploy --dry-run --config wrangler.jsonc"
  },
  "dependencies": {
    "@bufbuild/cel": "0.6.0",
    "@bufbuild/protobuf": "^2.12.1",
    "@cyspbot/github": "workspace:*",
    "@cyspbot/http": "workspace:*",
    "@cyspbot/oidc": "workspace:*",
    "@cyspbot/oidc-issuer-fly": "workspace:*",
    "@cyspbot/oidc-issuer-github-actions": "workspace:*",
    "jose": "6.2.3"
  }
}
