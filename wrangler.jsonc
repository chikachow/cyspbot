        "TEST_GITHUB_REPOSITORY_ID": "123456789",
        "TEST_GITHUB_REPOSITORY_VISIBILITY": "private",
      },
    },
    "production": {
      "name": "cyspbot",
      "durable_objects": {
        "bindings": [
          {
            "name": "DASHBOARD_SESSION",
            "class_name": "DashboardSessionObject",
          },
          {
            "name": "GITHUB_INSTALLATION",
            "class_name": "GitHubInstallationObject",
          },
          {
            "name": "OIDC_ISSUER_VERIFIER",
            "class_name": "OidcIssuerVerifierObject",
          },
        ],
      },
      "routes": [
        {
          "pattern": "cyspbot.chikachow.org",
          "custom_domain": true,
        },
      ],
      "vars": {
        "AUDIT_LOG_MAX_ENTRIES": "5000",
        "AUDIT_LOG_RETENTION_DAYS": "180",
        "GITHUB_API_BASE_URL": "https://api.github.com",
        "GITHUB_APP_ID": "2419473",
      },
      "secrets_store_secrets": [
        {
          "binding": "GITHUB_APP_PRIVATE_KEY",
          "secret_name": "CYSPBOT_GITHUB_APP_PRIVATE_KEY",
          "store_id": "d38c6b7fbcc143dba27208fa1c044e37",
        },
      ],
      "workers_dev": false,
    },
  },
}
