{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cyspbot",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "ai": {
    "binding": "AI",
    "remote": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "GITHUB_INSTALLATION",
        "class_name": "GitHubInstallationObject",
      },
      {
        "name": "OIDC_ISSUER_VERIFIER",
        "class_name": "OidcIssuerVerifierObject",
      },
    ],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cyspbot",
      "database_id": "35a687d9-6669-4021-8ce6-07def640e973",
      "migrations_dir": "migrations",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "PULL_REQUEST_HAIKU_QUEUE",
        "queue": "cyspbot-pr-haiku",
      },
    ],
    "consumers": [
      {
        "queue": "cyspbot-pr-haiku",
        "max_batch_size": 5,
        "max_batch_timeout": 10,
        "max_retries": 3,
      },
    ],
  },
  "routes": [
    {
      "pattern": "cyspbot.chikachow.org",
      "custom_domain": true,
    },
  ],
  "vars": {
    "AUDIT_LOG_MAX_ENTRIES": "5000",
    "AUDIT_LOG_RETENTION_DAYS": "180",
    "GITHUB_API_BASE_URL": "https://api.github.com",
    "GITHUB_APP_ID": "2419473",
    "GITHUB_APP_CLIENT_ID": "Iv23liTtjzogToOIUmVg",
    "PULL_REQUEST_HAIKU_ADMIN_GITHUB_USER_IDS": "742696",
    "PULL_REQUEST_HAIKU_TEXT_MODEL": "@cf/qwen/qwen3-30b-a3b-fp8",
  },
  "secrets_store_secrets": [
    {
      "binding": "GITHUB_APP_PRIVATE_KEY",
      "secret_name": "CYSPBOT_GITHUB_APP_PRIVATE_KEY",
      "store_id": "d38c6b7fbcc143dba27208fa1c044e37",
    },
  ],
  "preview_urls": false,
  "workers_dev": true,
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GitHubInstallationObject"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["OidcIssuerVerifierObject"],
    },
  ],
  "env": {
    "test": {
      "name": "cyspbot-test",
      "ai": {
        "binding": "AI",
        "remote": true,
      },
      "durable_objects": {
        "bindings": [
          {
            "name": "GITHUB_INSTALLATION",
            "class_name": "GitHubInstallationObject",
          },
          {
            "name": "OIDC_ISSUER_VERIFIER",
            "class_name": "OidcIssuerVerifierObject",
          },
        ],
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "cyspbot-test",
          "database_id": "00000000-0000-0000-0000-000000000000",
          "migrations_dir": "migrations",
        },
      ],
      "queues": {
        "producers": [
          {
            "binding": "PULL_REQUEST_HAIKU_QUEUE",
            "queue": "cyspbot-pr-haiku-test",
          },
        ],
        "consumers": [
          {
            "queue": "cyspbot-pr-haiku-test",
            "max_batch_size": 5,
            "max_batch_timeout": 10,
            "max_retries": 3,
          },
        ],
      },
      "vars": {
        "AUDIT_LOG_MAX_ENTRIES": "5000",
        "AUDIT_LOG_RETENTION_DAYS": "180",
        "DASHBOARD_SESSION_LOOKUP_SECRET": "test-dashboard-session-lookup-secret",
        "DASHBOARD_TOKEN_ENCRYPTION_SECRET": "test-dashboard-token-encryption-secret",
        "GITHUB_API_BASE_URL": "https://example.test/__test/github",
        "GITHUB_APP_ID": "12345",
        "GITHUB_APP_CLIENT_ID": "Iv1.testclientid",
        "GITHUB_APP_CLIENT_SECRET": "test-client-secret",
        "GITHUB_WEBHOOK_SECRET": "test-webhook-secret",
        "PULL_REQUEST_HAIKU_ADMIN_GITHUB_USER_IDS": "42",
        "PULL_REQUEST_HAIKU_TEXT_MODEL": "@cf/qwen/qwen3-30b-a3b-fp8",
      },
      "secrets_store_secrets": [
        {
          "binding": "GITHUB_APP_PRIVATE_KEY",
          "secret_name": "CYSPBOT_GITHUB_APP_PRIVATE_KEY",
          "store_id": "d38c6b7fbcc143dba27208fa1c044e37",
        },
      ],
    },
  },
}
