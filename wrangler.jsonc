{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cyspbot-dev",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "vars": {
    "AUDIT_LOG_MAX_ENTRIES": "5000",
    "AUDIT_LOG_RETENTION_DAYS": "180",
    "GITHUB_API_BASE_URL": "https://api.github.com",
    "GITHUB_APP_ID": "2419473",
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "DASHBOARD_SESSION",
        "class_name": "DashboardSessionObject",
      },
      {
        "name": "GITHUB_INSTALLATION",
        "class_name": "GitHubInstallationObject",
      },
      {
        "name": "OIDC_ISSUER_VERIFIER",
        "class_name": "OidcIssuerVerifierObject",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GitHubInstallationObject"],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["OidcIssuerVerifierObject"],
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["DashboardSessionObject"],
    },
  ],
  "env": {
    "preview": {
      "name": "cyspbot-preview",
      "durable_objects": {
        "bindings": [
          {
            "name": "DASHBOARD_SESSION",
            "class_name": "DashboardSessionObject",
          },
          {
            "name": "GITHUB_INSTALLATION",
            "class_name": "GitHubInstallationObject",
          },
          {
            "name": "OIDC_ISSUER_VERIFIER",
            "class_name": "OidcIssuerVerifierObject",
          },
        ],
      },
      "vars": {
        "AUDIT_LOG_MAX_ENTRIES": "5000",
        "AUDIT_LOG_RETENTION_DAYS": "180",
        "GITHUB_API_BASE_URL": "https://api.github.com",
        "GITHUB_APP_ID": "2419473",
      },
    },
    "test": {
      "name": "cyspbot-test",
      "durable_objects": {
        "bindings": [
          {
            "name": "DASHBOARD_SESSION",
            "class_name": "DashboardSessionObject",
          },
          {
            "name": "GITHUB_INSTALLATION",
            "class_name": "GitHubInstallationObject",
          },
          {
            "name": "OIDC_ISSUER_VERIFIER",
            "class_name": "OidcIssuerVerifierObject",
          },
