{
  "name": "cyspbot",
  "version": "0.0.2-rc4",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --run format:check && node --run lint && node --run typecheck && node --run test && node --run wrangler:check",
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy --env production",
    "dev": "wrangler dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --report-unused-disable-directives .",
    "lint:fix": "oxlint --type-aware --fix .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "types:worker": "wrangler types",
    "wrangler:check": "wrangler deploy --dry-run --env production",
    "wrangler:whoami": "wrangler whoami"
  },
  "dependencies": {
    "jose": "6.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.15.2",
    "@cloudflare/workers-types": "4.20260503.1",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.19.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.87.0"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.33.0"
}
